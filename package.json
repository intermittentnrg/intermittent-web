{
  "name": "intermittent-web",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "node --experimental-strip-types --watch src/server.ts --dev",
    "build": "rm -rf dist && vite build",
    "build:lambda": "npm run build && rm -rf tmp/lambda && mkdir -p tmp/lambda/src && cp -R dist src public package.json package-lock.json tmp/lambda/ && cp -R lambda-assets/* tmp/lambda/ && npm ci --omit=dev --prefix tmp/lambda && find tmp/lambda/node_modules -type f \\( -name '*.map' -o -name '*.ts' -o -name '*.d.ts' -o -name '*.md' \\) -delete",
    "start": "node --experimental-strip-types src/server.ts",
    "render:price-map": "npm run render:price-map:europe --",
    "render:price-map:europe": "PRICE_MAP_PROFILE=europe node --experimental-strip-types src/scripts/renderPriceMap.ts",
    "render:price-map:australia": "PRICE_MAP_PROFILE=australia node --experimental-strip-types src/scripts/renderPriceMap.ts",
    "render:nukemap": "PRICE_MAP_PROFILE=nukemap node --experimental-strip-types src/scripts/renderPriceMap.ts",
    "publish:price-map": "node --experimental-strip-types src/scripts/publishPriceMap.ts",
    "test": "vitest",
    "test:e2e": "wdio run ./wdio.conf.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@atproto/api": "^0.20.0",
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^11.1.1",
    "@xdevplatform/xdk": "^0.5.0",
    "dotenv": "^17.4.2",
    "echarts": "^6.0.0",
    "ejs": "^5.0.2",
    "fastify": "^5.8.5",
    "pg": "^8.20.0",
    "pngjs": "^7.0.0",
    "skia-canvas": "^3.0.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@types/pngjs": "^6.0.5",
    "@wdio/cli": "^9.27.1",
    "@wdio/junit-reporter": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "expect-webdriverio": "^5.6.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.6",
    "webdriverio": "^9.27.1"
  }
}
