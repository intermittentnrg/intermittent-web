{
  "name": "intermittent-web",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts --dev",
    "build": "tsc && vite build",
    "build:lambda": "npm run build && rm -rf tmp/lambda && mkdir -p tmp/lambda/src && cp -R dist public package.json package-lock.json tmp/lambda/ && cp -R src/views tmp/lambda/src/views && cp -R lambda-assets/* tmp/lambda/ && npm ci --omit=dev --prefix tmp/lambda",
    "start": "node dist/server.js",
    "render:price-map:frames": "node dist/scripts/renderPriceMapFrames.js",
    "render:price-map:video": "node dist/scripts/renderPriceMapVideo.js",
    "render:price-map:frames:dev": "tsx src/scripts/renderPriceMapFrames.ts",
    "render:price-map:video:dev": "tsx src/scripts/renderPriceMapVideo.ts",
    "render:price-map": "npm run render:price-map:frames && npm run render:price-map:video",
    "test": "vitest",
    "test:e2e": "wdio run ./wdio.conf.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/aws-lambda": "^6.4.0",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^11.1.1",
    "@hotwired/stimulus": "^3.2.2",
    "@napi-rs/canvas": "^1.0.0",
    "dotenv": "^17.4.2",
    "echarts": "^6.0.0",
    "ejs": "^5.0.2",
    "fastify": "^5.8.5",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.6.2",
    "@types/pg": "^8.20.0",
    "@wdio/cli": "^9.27.1",
    "@wdio/junit-reporter": "^9.27.1",
    "@wdio/local-runner": "^9.27.1",
    "@wdio/mocha-framework": "^9.27.1",
    "@wdio/spec-reporter": "^9.27.1",
    "expect-webdriverio": "^5.6.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.6",
    "webdriverio": "^9.27.1"
  }
}
