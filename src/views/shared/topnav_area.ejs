<div id="topnav-area" class="topnav-item" data-areas-data='<%- areasJson %>'>
  <label for="location-selector-btn">Location</label>
  <button type="button" id="location-selector-btn" class="dropdown-btn location-selector-btn" >
    <span class="dropdown-value"><%= params.area %></span>
    <span class="dropdown-arrow">▼</span>
  </button>
  <div class="area-menu">
    <div class="location-step visible" data-step="region">
      <div class="step-header">
        <button type="button" class="step-close">×</button>
        <h3></h3>
        <button type="button" class="step-back" style="visibility: hidden;">←</button>
      </div>
      <div class="step-options">
        <% regions.forEach((region) => { %>
          <button type="button" class="step-option" data-region="<%= region %>">
            <span class="option-text"><%= region.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></span>
            <span class="option-arrow">→</span>
          </button>
        <% }) %>
      </div>
    </div>
    <div class="location-step" data-step="areaType">
      <div class="step-header">
        <button type="button" class="step-back">←</button>
        <h3 data-area-type-title>Select Area Type</h3>
        <button type="button" class="step-close">×</button>
      </div>
      <div class="step-options" data-area-type-options></div>
    </div>
    <div class="location-step visible" data-step="areas">
      <div class="step-header">
        <button type="button" class="step-back">←</button>
        <h3 data-area-title>Select Areas</h3>
        <button type="button" class="step-close">×</button>
      </div>
      <div class="step-areas" data-area-options>
        <div class="dropdown-option">
          <input type="checkbox" class="dropdown-checkbox" id="area-all" value="all">
          <label class="dropdown-label" for="area-all">All areas</label>
        </div>
        <div class="dropdown-option-divider"></div>
        <div class="individual-areas"></div>
      </div>
      <div class="step-actions">
        <button type="button" class="action-btn apply">Apply</button>
      </div>
    </div>
  </div>
</div>
