<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title><%= pageTitle || 'intermittent.energy' %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <% if (typeof dashboardType !== 'undefined' && dashboardType) { %>
      <meta name="twitter:card" content="summary_large_image">
      <meta property="twitter:site" content="@IntermittentNRG">
      <meta property="og:title" content="<%= pageTitle %>">
      <meta property="og:description" content="High resolution graphs of electricity grid data. Powered by @TimescaleDB">
      <% if (typeof imageUrl !== 'undefined' && imageUrl) { %>
        <meta property="og:image" content="<%= imageUrl %>">
        <meta property="og:image:type" content="image/png">
        <meta property="og:image:width" content="1200">
        <meta property="og:image:height" content="630">
      <% } %>
    <% } %>
    <%- include('critical_css') %>
    <link rel="stylesheet" href="<%= entrypointUrl('public/application.css') %>">
    <link rel="stylesheet" href="<%= entrypointUrl('public/topnav.css') %>">
    <link rel="stylesheet" href="<%= entrypointUrl('public/topnav-area.css') %>">
    <link rel="stylesheet" href="<%= entrypointUrl('public/topnav-dashboard.css') %>">
    <link rel="stylesheet" href="<%= entrypointUrl('public/topnav-date.css') %>">
    <%- scriptTags('public/app.js') %>
    <%- include('google_analytics') %>
  </head>
  <body>
