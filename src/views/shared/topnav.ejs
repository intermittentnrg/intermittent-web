<nav id="topnav" class="topnav">
  <div id="topnav-logo">
    <a href="/" class="logo-link">
      <span class="logo-text">intermittent.energy</span>
      <span class="logo-icon">⚡</span>
    </a>
    <div class="logo-subtitle">
      <a href="https://www.tigerdata.com/timescaledb" target="_blank" rel="noopener noreferrer">Powered by TimescaleDB</a>
    </div>
  </div>

  <div id="topnav-content">
    <%- include('topnav_area') %>
    <%- include('topnav_date') %>
    <%- include('topnav_dashboard') %>

    <div class="topnav-item production-type-selector" id="dashboard-options-production-type-section"
     style="display: <%= productionDashboards.has(dashboardType) ? 'flex' : 'none' %>;">
      <label>Production Type</label>
      <button type="button" class="dropdown__trigger">
        <span class="dropdown__value" id="dashboard-options-selected-text"><%= productionType || 'All' %></span>
        <span class="dropdown__arrow">▼</span>
      </button>
      <div class="dropdown__panel" id="dashboard-options-menu">
        <div class="dropdown__content" id="dashboard-options-production-type-options"></div>
        <div class="dropdown__actions">
          <button type="button" class="dropdown__apply">Apply</button>
        </div>
      </div>
    </div>

    <div class="topnav-item multiplier-selector dashboard-options-simulation-section" id="dashboard-options-simulation-section"
         style="display: <%= dashboardType === 'simulation' ? 'flex' : 'none' %>;">
      <label>Multipliers</label>
      <button type="button" class="dropdown__trigger">
        <span class="dropdown__value" id="dashboard-options-multiplier-selected-text">Edit</span>
        <span class="dropdown__arrow">▼</span>
      </button>
      <div class="dropdown__panel" id="dashboard-options-multiplier-menu">
        <div class="multiplier-options">
          <div class="multiplier-row"><label>Demand</label><input type="number" class="multiplier-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-demand-input"></div>
          <div class="multiplier-row"><label>Nuclear</label><input type="number" class="multiplier-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-nuclear-input"></div>
          <div class="multiplier-row"><label>Wind</label><input type="number" class="multiplier-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-wind-input"></div>
          <div class="multiplier-row"><label>Solar</label><input type="number" class="multiplier-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-solar-input"></div>
        </div>
        <div class="dropdown__actions"><button type="button" class="dropdown__apply">Apply</button></div>
      </div>
    </div>

    <div id="dashboard-options-electricity-mix-section" class="topnav-item"
         style="display: <%= ['electricity_mix', 'generation', 'sweden'].includes(dashboardType) ? 'flex' : 'none' %>;">
      <label for="topnav-prices-checkbox">Prices</label>
      <div class="checkbox-wrapper"><input id="topnav-prices-checkbox" type="checkbox" <%= prices ? 'checked' : '' %>></div>
    </div>

    <div id="dashboard-options-temps-section" class="topnav-item"
         style="display: <%= dashboardType === 'generation' ? 'flex' : 'none' %>;">
      <label for="topnav-temps-checkbox">Temps</label>
      <div class="checkbox-wrapper"><input id="topnav-temps-checkbox" type="checkbox" <%= temps ? 'checked' : '' %>></div>
    </div>

    <div id="dashboard-options-load-section" class="topnav-item"
         style="display: <%= dashboardType === 'generation' ? 'flex' : 'none' %>;">
      <label for="topnav-load-checkbox">Load</label>
      <div class="checkbox-wrapper"><input id="topnav-load-checkbox" type="checkbox" <%= load ? 'checked' : '' %>></div>
    </div>

    <div id="dashboard-options-transmission-checkbox-section" class="topnav-item"
         style="display: <%= ['electricity_mix', 'generation', 'sweden'].includes(dashboardType) ? 'flex' : 'none' %>;">
      <label for="topnav-transmission-checkbox">Transmission</label>
      <div class="checkbox-wrapper"><input id="topnav-transmission-checkbox" type="checkbox" <%= transmission ? 'checked' : '' %>></div>
    </div>

    <div id="dashboard-options-transmission-section" class="topnav-item transmission-selector"
         style="display: <%= dashboardType === 'transmission' ? 'flex' : 'none' %>;">
      <label>Transmission Line</label>
      <button type="button" class="dropdown__trigger">
        <span class="dropdown__value" id="dashboard-options-transmission-selected-text">Select line</span>
        <span class="dropdown__arrow">▼</span>
      </button>
      <div class="dropdown__panel" id="dashboard-options-transmission-menu">
        <div class="dropdown__content" id="dashboard-options-transmission-options"></div>
        <div class="dropdown__actions"><button type="button" class="dropdown__apply">Apply</button></div>
      </div>
    </div>

    <div id="dashboard-options-unit-section" class="topnav-item unit-selector dashboard-options-per-unit-section"
         style="display: <%= perUnitDashboards.has(dashboardType) ? 'flex' : 'none' %>;">
      <label>Units</label>
      <button type="button" class="dropdown__trigger">
        <span class="dropdown__value" id="dashboard-options-unit-selected-text"><%= unitLabel || 'All' %></span>
        <span class="dropdown__arrow">▼</span>
      </button>
      <div class="dropdown__panel" id="dashboard-options-unit-menu">
        <div class="dropdown__content" id="dashboard-options-unit-options"></div>
        <div class="dropdown__actions"><button type="button" class="dropdown__apply">Apply</button></div>
      </div>
    </div>
  </div>
</nav>
