<nav id="topnav" class="topnav" data-controller="topnav">
  <div id="topnav-logo">
    <a href="/" class="logo-link">
      <span class="logo-text">intermittent.energy</span>
      <span class="logo-icon">⚡</span>
    </a>
    <div class="logo-subtitle">
      <a href="https://www.tigerdata.com/timescaledb" target="_blank" rel="noopener noreferrer">Powered by TimescaleDB</a>
    </div>
  </div>

  <div id="topnav-content" data-controller="dashboard-options">
    <%- include('topnav_area') %>
    <%- include('topnav_date') %>
    <%- include('topnav_dashboard') %>

    <div class="topnav-item production-type-selector" style="display: <%= productionDashboards.has(dashboardType) ? 'flex' : 'none' %>;">
      <label>Production Type</label>
      <button type="button" class="dropdown-btn"><span class="dropdown-value"><%= productionType || 'All' %></span><span class="dropdown-arrow">▼</span></button>
    </div>

    <div id="topnav-prices" class="topnav-item" style="display: <%= ['electricity_mix', 'generation'].includes(dashboardType) ? 'flex' : 'none' %>;">
      <label>Prices</label>
      <div class="checkbox-wrapper"><input type="checkbox" <%= prices ? 'checked' : '' %>></div>
    </div>

    <div id="topnav-temps" class="topnav-item" style="display: <%= dashboardType === 'generation' ? 'flex' : 'none' %>;">
      <label>Temps</label>
      <div class="checkbox-wrapper"><input type="checkbox" <%= temps ? 'checked' : '' %>></div>
    </div>

    <div id="topnav-load" class="topnav-item" style="display: <%= dashboardType === 'generation' ? 'flex' : 'none' %>;">
      <label>Load</label>
      <div class="checkbox-wrapper"><input type="checkbox" <%= load ? 'checked' : '' %>></div>
    </div>

    <div id="topnav-production-types" class="topnav-item per-unit-production-type-selector" style="display: <%= perUnitDashboards.has(dashboardType) ? 'flex' : 'none' %>;">
      <label>Production Type</label>
      <button type="button" class="dropdown-btn"><span class="dropdown-value"><%= productionType || 'All' %></span><span class="dropdown-arrow">▼</span></button>
    </div>

    <div id="topnav-export" class="topnav-item export-btn">
      <label>Export</label>
      <button type="button" class="export-download-btn" title="Download chart data">Download</button>
    </div>
  </div>
</nav>
