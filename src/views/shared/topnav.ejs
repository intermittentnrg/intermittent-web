<nav id="topnav" class="topnav">
  <div id="topnav-logo">
    <a href="/" class="logo-link">
      <span class="logo-text">intermittent.energy</span>
      <span class="logo-icon">⚡</span>
    </a>
    <div class="logo-subtitle">
      <a href="https://www.tigerdata.com/timescaledb" target="_blank" rel="noopener noreferrer">Powered by TimescaleDB</a>
    </div>
  </div>

  <div id="topnav-content">
    <%- include('topnav_area') %>
    <%- include('topnav_date') %>
    <%- include('topnav_dashboard') %>

    <%- include('topnav_multi_select', {
      sectionClass: 'production-type-selector',
      targetPrefix: 'production-type',
      label: 'Production Type',
      defaultValue: productionType || 'All',
      displayFeature: 'production_type_selector'
    }) %>

    <div class="topnav-item multiplier-selector dashboard-options-simulation-section" id="dashboard-options-simulation-section"
         style="display: <%= dashboardHasFeature(dashboardType, 'simulation_multipliers') ? 'flex' : 'none' %>;">
      <label>Multipliers</label>
      <button type="button" class="dropdown__trigger">
        <span class="dropdown__value dashboard-options-multiplier-selected-text" id="dashboard-options-multiplier-selected-text">Edit</span>
        <span class="dropdown__arrow">▼</span>
      </button>
      <div class="dropdown__panel dashboard-options-multiplier-menu" id="dashboard-options-multiplier-menu">
        <div class="multiplier-options">
          <div class="multiplier-row"><label>Demand</label><input type="number" class="multiplier-input dashboard-options-demand-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-demand-input"></div>
          <div class="multiplier-row"><label>Nuclear</label><input type="number" class="multiplier-input dashboard-options-nuclear-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-nuclear-input"></div>
          <div class="multiplier-row"><label>Wind</label><input type="number" class="multiplier-input dashboard-options-wind-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-wind-input"></div>
          <div class="multiplier-row"><label>Solar</label><input type="number" class="multiplier-input dashboard-options-solar-input" value="1.0" step="0.1" min="0" max="10" id="dashboard-options-solar-input"></div>
        </div>
        <div class="dropdown__actions"><button type="button" class="dropdown__apply">Apply</button></div>
      </div>
    </div>

    <div id="dashboard-options-electricity-mix-section" class="topnav-item dashboard-options-electricity-mix-section"
         style="display: <%= dashboardHasFeature(dashboardType, 'prices_checkbox') ? 'flex' : 'none' %>;">
      <label for="topnav-prices-checkbox">Prices</label>
      <div class="checkbox-wrapper"><input id="topnav-prices-checkbox" type="checkbox" <%= prices ? 'checked' : '' %>></div>
    </div>

    <div id="dashboard-options-temps-section" class="topnav-item dashboard-options-temps-section"
         style="display: <%= dashboardHasFeature(dashboardType, 'temps_checkbox') ? 'flex' : 'none' %>;">
      <label for="topnav-temps-checkbox">Temps</label>
      <div class="checkbox-wrapper"><input id="topnav-temps-checkbox" type="checkbox" <%= temps ? 'checked' : '' %>></div>
    </div>

    <div id="dashboard-options-load-section" class="topnav-item dashboard-options-load-section"
         style="display: <%= dashboardHasFeature(dashboardType, 'load_checkbox') ? 'flex' : 'none' %>;">
      <label for="topnav-load-checkbox">Load</label>
      <div class="checkbox-wrapper"><input id="topnav-load-checkbox" type="checkbox" <%= load ? 'checked' : '' %>></div>
    </div>

    <div id="dashboard-options-transmission-checkbox-section" class="topnav-item dashboard-options-transmission-checkbox-section"
         style="display: <%= dashboardHasFeature(dashboardType, 'transmission_checkbox') ? 'flex' : 'none' %>;">
      <label for="topnav-transmission-checkbox">Transmission</label>
      <div class="checkbox-wrapper"><input id="topnav-transmission-checkbox" type="checkbox" <%= transmission ? 'checked' : '' %>></div>
    </div>

    <%- include('topnav_multi_select', {
      sectionClass: 'transmission-selector',
      targetPrefix: 'transmission',
      label: 'Transmission Line',
      defaultValue: 'Select line',
      displayFeature: 'transmission_selector'
    }) %>

    <%- include('topnav_multi_select', {
      sectionClass: 'unit-selector',
      targetPrefix: 'unit',
      label: 'Units',
      defaultValue: unitLabel || 'All',
      displayFeature: 'per_unit_selector'
    }) %>
  </div>
</nav>
