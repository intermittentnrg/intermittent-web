{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "es2024.sharedmemory"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",

    "strict": true,

    "esModuleInterop": true,
    "skipLibCheck": true,

    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "noEmit": true
  },

  "include": ["src"]
}
