# syntax=docker/dockerfile:1

FROM node:22-bookworm-slim

ENV NODE_ENV=development

ARG TERRAFORM_VERSION=1.15.3

# fontconfig + a basic TrueType font let server-side ECharts canvas rendering
# draw text cleanly. dumb-init gives the dev server proper signal handling under Docker.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    dumb-init \
    ffmpeg \
    fontconfig \
    fonts-dejavu-core \
    postgresql-client \
    unzip \
  && dpkg_arch="$(dpkg --print-architecture)" \
  && case "$dpkg_arch" in \
    amd64) terraform_arch="amd64" ;; \
    arm64) terraform_arch="arm64" ;; \
    *) echo "Unsupported architecture for Terraform: $dpkg_arch" >&2; exit 1 ;; \
  esac \
  && curl -fsSLo /tmp/terraform.zip "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_${terraform_arch}.zip" \
  && unzip /tmp/terraform.zip -d /usr/local/bin \
  && rm /tmp/terraform.zip \
  && terraform version \
  && rm -rf /var/lib/apt/lists/* \
  && mkdir -p /workspace/node_modules \
  && chown -R node: /workspace

WORKDIR /workspace

USER node

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--", "/workspace/docker/dev-entrypoint.sh"]
CMD ["npm", "run", "dev"]
