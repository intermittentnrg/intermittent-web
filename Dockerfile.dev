# syntax=docker/dockerfile:1

FROM node:22-bookworm-slim

ENV NODE_ENV=development

# fontconfig + a basic TrueType font let server-side ECharts canvas rendering
# draw text cleanly. dumb-init gives the dev server proper signal handling under Docker.
# mesa-va-drivers (from non-free) provides AMD VAAPI for ffmpeg HW encoding.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    dumb-init \
    ffmpeg \
    fontconfig \
    fonts-dejavu-core \
    fonts-noto-color-emoji \
    git \
    mesa-va-drivers \
    mesa-vulkan-drivers \
    postgresql-client \
    unzip \
    vainfo \
  && rm -rf /var/lib/apt/lists/*
RUN npm install -g @earendil-works/pi-coding-agent \
  && pi install npm:@narumitw/pi-retry \
  && mkdir -p /workspace/node_modules \
  && chown -R node: /workspace \
  && groupadd -g 109 render \
  && usermod -aG video,render node

WORKDIR /workspace

USER node

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--", "/workspace/docker/dev-entrypoint.sh"]
CMD ["npm", "run", "dev"]
