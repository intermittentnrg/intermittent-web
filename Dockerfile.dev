# syntax=docker/dockerfile:1

FROM node:22-bookworm-slim

ENV NODE_ENV=development

ARG TERRAFORM_VERSION=1.15.3

# fontconfig + a basic TrueType font let server-side ECharts canvas rendering
# draw text cleanly. dumb-init gives the dev server proper signal handling under Docker.
RUN apt-get update \
  && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    dumb-init \
    ffmpeg \
    fontconfig \
    fonts-dejavu-core \
    postgresql-client \
    unzip \
  && npm install -g @earendil-works/pi-coding-agent \
  && rm -rf /var/lib/apt/lists/* \
  && mkdir -p /workspace/node_modules \
  && chown -R node: /workspace

WORKDIR /workspace

USER node

EXPOSE 3000

ENTRYPOINT ["dumb-init", "--", "/workspace/docker/dev-entrypoint.sh"]
CMD ["npm", "run", "dev"]
